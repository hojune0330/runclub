# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database (runtime data)
*.db
*.db-wal
*.db-shm

# Screenshots and dev artifacts
*.png
# PWA / favicon assets under public/ are tracked despite the *.png rule above.
!public/**/*.png
!public/*.png
screenshot-*.js
check-load.js
verify-*.js
core
runclub.db
runclub.db-*
shots.js
verify-clubhub.js
