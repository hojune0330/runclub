# ════════════════════════════════════════════════════════════════════
# Required (production)
# ════════════════════════════════════════════════════════════════════

# PostgreSQL connection string. On Render this is wired automatically
# from the linked database via render.yaml `fromDatabase`.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# JWT signing secret. MUST be ≥32 chars in production (or boot fails).
# Generate one with: `openssl rand -base64 48`
JWT_SECRET=replace-me-with-a-long-random-string-of-32-chars-or-more

# ════════════════════════════════════════════════════════════════════
# Seed gating  (production-only — leave unset locally)
# ════════════════════════════════════════════════════════════════════
# Both must be set for POST /api/seed to run. Set them once before the
# first seed, run the seed, then immediately revert ALLOW_SEED to 'false'
# (or remove SEED_TOKEN) and redeploy.
ALLOW_SEED=false
SEED_TOKEN=

# Seed mode: 'production' (only the env-configured admin + pass products
# + recurring sessions) or 'demo' (the legacy 4 demo members + sample
# passes + admin/admin). In production, set this to 'production'.
SEED_MODE=production

# First admin account. REQUIRED when SEED_MODE=production.
# Phone format: 010-1234-5678. Password: ≥ 8 chars (will be hashed).
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=관리자
SEED_ADMIN_EMAIL=

# ════════════════════════════════════════════════════════════════════
# Google Sheets sync (manager-friendly mirror of member/pass/attendance)
# ════════════════════════════════════════════════════════════════════
# Master toggle. When 'false' (default), every sync call is a no-op so
# local dev / CI never reaches Google. Set to 'true' in production once
# the service account + sheet are provisioned.
SHEET_SYNC_ENABLED=false

# Admin-reviewed Google Sheets → web import for Members J~O manager metadata.
# Core protected fields (A~I: name/phone/role/active/etc.) remain web/DB-owned.
SHEET_MEMBER_IMPORT_ENABLED=false

# Service Account credentials. Either:
#   • paste the full JSON on one line, OR
#   • paste the base64-encoded JSON (recommended on Render — avoids quote
#     escaping issues). The library auto-detects which form was supplied.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Spreadsheet ID — from the URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Tab names. Defaults match scripts/sheet-init.mjs output; only override
# if you renamed tabs after initial setup.
GOOGLE_SHEET_TAB_MEMBERS=Members
GOOGLE_SHEET_TAB_PASSES=Passes
GOOGLE_SHEET_TAB_ATTENDANCE=Attendance
GOOGLE_SHEET_TAB_SESSIONS=Sessions
GOOGLE_SHEET_TAB_ADMIN_LOG=AdminLog
GOOGLE_SHEET_TAB_PASS_PRODUCTS=PassProducts

# Retry worker tunables (PR-3)
SHEET_SYNC_BATCH_SIZE=500
SHEET_SYNC_RETRY_INTERVAL_MIN=1

# ════════════════════════════════════════════════════════════════════
# Toss Payments (PR-6 — member-initiated checkout)
# ════════════════════════════════════════════════════════════════════
# 1) Sign up at https://developers.tosspayments.com → "내 개발 정보"
# 2) Toggle "테스트" mode at the top.
# 3) Copy the two keys below. The CLIENT key is safe to ship to the
#    browser (NEXT_PUBLIC_*); the SECRET key MUST stay server-side.
# 4) During development, use the test keys. Switch to live keys
#    (live_ck_* / live_sk_*) only after a successful test transaction
#    AND after enabling webhook IP whitelisting in production.
#
# Test card for sandbox: 4330-1234-1234-1234, any future expiry, any CVC.

# Public client key — embedded in the browser bundle. Used by
# loadTossPayments() in PassCatalog.tsx to open the payment widget.
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# Secret key — used ONLY in /api/payments/confirm (and never sent to the
# client) to call Toss's /v1/payments/confirm with HTTP Basic auth.
# Leaks of this key let an attacker capture/cancel real charges.
TOSS_SECRET_KEY=

# Public base URL of THIS app. Used to build successUrl/failUrl that
# Toss redirects the user back to after the SDK closes. Examples:
#   • Local dev:   http://localhost:3000
#   • Render:      https://runclub.onrender.com
#   • Custom dom:  https://app.runclub.kr
# No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public server base URL used by OAuth providers. No trailing slash.
# Local dev: http://localhost:3000 / Render: https://runclub.onrender.com
APP_BASE_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════════════
# Training data integrations (Strava live, Garmin/Apple preparation)
# ════════════════════════════════════════════════════════════════════
# Strava: create an API application and set callback domain to this app host.
# Callback path: /api/integrations/strava/callback
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Garmin: requires Garmin Connect Developer Program business approval.
# These are placeholders for the approved Activity/Health API credentials.
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_WEBHOOK_SECRET=

# Apple Health: no web OAuth. Native iOS HealthKit app uses these app identifiers.
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=

# ════════════════════════════════════════════════════════════════════
# Local development convenience
# ════════════════════════════════════════════════════════════════════
NODE_ENV=development
